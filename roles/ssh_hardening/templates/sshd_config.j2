#jinja2: trim_blocks: "true", lstrip_blocks: "true"
{{ ansible_managed | comment }}
# Generated by Ansible role {{ ansible_role_name }}

# This is the sshd server system-wide configuration file. See
# sshd_config(5) for more information.

{% if sshd_version is version('7.4', '<') %}
Protocol 2
{% endif %}

{% for port in ssh_server_ports %}
Port {{ port }}
{% endfor %}
AddressFamily {{ 'any' if (network_ipv6_enabled | bool) else 'inet' }}
{% for address in ssh_server_listen_addresses %}
ListenAddress {{ address }}
{% endfor %}

# Logging
# =======
SyslogFacility {{ ssh_server_syslog_facility }}
LogLevel {{ ssh_server_log_level }}

# Authentication
# ==============
LoginGraceTime {{ ssh_server_login_grace_time }}
PermitRootLogin {{ 'yes' if (ssh_server_permit_root_login | bool) else 'no' }}
StrictModes {{ 'yes' if (ssh_server_strict_modes | bool) else 'no' }}
MaxAuthTries {{ ssh_server_max_auth_tries }}
MaxSessions {{ ssh_server_max_sessions }}
AuthenticationMethods {{ ssh_server_authentication_methods }}
PubkeyAuthentication {{ 'yes' if (ssh_server_pubkey_authentication | bool) else 'no' }}
PasswordAuthentication {{ 'yes' if (ssh_server_password_authentication | bool) else 'no' }}
KbdInteractiveAuthentication {{ 'yes' if (ssh_server_kbd_interactive_authentication | bool) else 'no' }}
ChallengeResponseAuthentication {{ 'yes' if (ssh_server_challenge_response_authentication | bool) else 'no' }}
UsePAM {{ 'yes' if (ssh_server_use_pam | bool) else 'no' }}
IgnoreRhosts {{ 'yes' if (ssh_server_ignore_rhosts | bool) else 'no' }}
HostbasedAuthentication {{ 'yes' if (ssh_server_host_based_authentication | bool) else 'no' }}
PermitEmptyPasswords {{ 'yes' if (ssh_server_permit_empty_passwords | bool) else 'no' }}

# <start>:<rate>:<full>
# <start> - Number of unauthenticated connections before random drop starts
# <rate> - Percentage chance to drop additional connections
# <full> - Maximum unauthenticated connections before all are rejected
MaxStartups {{ ssh_server_max_startups }}

# Network
# =======
PermitTunnel {{ ssh_server_permit_tunnel }}

DisableForwarding {{ 'yes' if (ssh_server_disable_forwarding | bool) else 'no' }}
{% if (ssh_server_disable_forwarding | bool) %}
AllowTcpForwarding {{ 'yes' if (ssh_server_allow_tcp_forwarding | bool) else 'no' }}
{% endif %}
{% if (ssh_server_allow_agent_forwarding | bool) %}
AllowAgentForwarding {{ 'yes' if (ssh_server_allow_agent_forwarding | bool) else 'no' }}
{% endif %}
{% if (ssh_server_gateway_ports | bool) %}
GatewayPorts {{ 'yes' if (ssh_server_gateway_ports | bool) else 'no' }}
{% endif %}
{% if (ssh_server_x11_forwarding | bool) %}
X11Forwarding {{ 'yes' if (ssh_server_x11_forwarding | bool) else 'no' }}
{% endif %}

PermitUserEnvironment {{ 'yes' if (ssh_server_permit_user_environment | bool) else 'false' }}

{% if (ssh_server_internal_sftp | bool) %}
Subsystem sftp internal-sftp
{% endif %}

# Cryptography
# ============

KexAlgorithms {{ ssh_kex_algorithms | join(',') }}

Ciphers {{ ssh_ciphers | join(',') }}

MACs {{ ssh_macs | join(',') }}

HostKeyAlgorithms {{ ssh_host_key_algorithms | join(',') }}